# Copier vers .env pour le dev local. À l'évaluation, le harness injecte les
# vraies valeurs dans l'environnement (ne jamais embarquer de .env dans l'image).
FIREWORKS_BASE_URL=
FIREWORKS_API_KEY=

# --- Optionnel, dev local uniquement ---
# FIREWORKS_MODE=mock              # mock | live | auto (défaut auto = live si clé présente, sinon mock)
# ALLOWED_MODELS=                  # ex: minimax-m3,kimi-k2p7-code (liste publiée au launch day)
# LOCAL_MODEL_PATH=models/model.gguf
# INPUT_PATH=local_io/input/tasks.json
# OUTPUT_PATH=local_io/output/results.json
