# Copy to .env for local development. At evaluation time the harness injects
# the real values into the environment (never ship a .env inside the image).
FIREWORKS_BASE_URL=
FIREWORKS_API_KEY=

# --- Optional, local development only ---
# FIREWORKS_MODE=mock              # mock | live | auto (default auto = live if key present, else mock)
# ALLOWED_MODELS=                  # e.g. minimax-m3,kimi-k2p7-code (list published on launch day)
# LOCAL_MODEL_PATH=models/model.gguf
# INPUT_PATH=local_io/input/tasks.json
# OUTPUT_PATH=local_io/output/results.json
